{
  "server": {
    "url": "opc.tcp://127.0.0.1:53530/OPCUA/SimulationServer",
    "timeoutInMillis": 5000,
    "scanPeriodInMillis": 3600000,
    "pollPeriodInMillis": 5000,
    "enableSubscriptions": true,
    "subCheckPeriodInMillis": 100,
    "showMap": false,
    "security": "Basic128Rsa15",
    "identity": {
      "type": "anonymous"
    }
  },
  "mapping": [
    {
      "deviceNodeSource": "path",
      "deviceNodePattern": "Root\\.Objects\\.Objects\\.Simulation",
      "deviceInfo": {
        "deviceNameExpression": "${ns=3;s=85/0:Simulation}",
        "deviceNameExpressionSource": "identifier",
        "deviceProfileExpressionSource": "identifier",
        "deviceProfileExpression": "${ns=3;i=1015}"
      },
      "timeseries": [
        {
          "key": "tag1",
          "type": "identifier",
          "value": "${ns=3;i=1008}"
        }
      ]
    }
  ],
  "logLevel": "INFO",
  "name": "opcua",
  "enableRemoteLogging": false,
  "id": "1270ed83-a808-4708-9f1c-dc7cb3656371",
  "configVersion": "3.8.1"
}